@startuml 03-uart-tx-state
skinparam backgroundColor white
skinparam state {
  BackgroundColor LightGray
  BorderColor DarkGray
  FontSize 12
  FontName Monospace
}
skinparam ArrowColor DarkGray
skinparam ArrowFontSize 11
skinparam ArrowFontName Monospace

[*] --> IDLE : rst

state IDLE  : txd = 1\ntx_ready = 1
state START : txd = 0\n[CLKS_PER_BIT]
state DATA  : txd = data_buf[bit_idx]\n[CLKS_PER_BIT × 8 bits]
state STOP  : txd = 1\n[CLKS_PER_BIT]

IDLE  --> START : tx_valid
START --> DATA  : timer = 0\nbit_idx = 0
DATA  --> DATA  : timer = 0\nbit_idx < 7\nbit_idx++
DATA  --> STOP  : timer = 0\nbit_idx = 7
STOP  --> IDLE  : timer = 0
@enduml
