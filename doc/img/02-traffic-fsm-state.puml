@startuml 02-traffic-fsm-state

skinparam state {
    BackgroundColor #f5f5f5
    BorderColor #555555
    FontColor #222222
}
skinparam backgroundColor #ffffff
skinparam defaultFontColor #222222
skinparam ArrowColor #444444

[*] --> S_GREEN : rst

state "S_GREEN\ngreen=1" as S_GREEN
state "S_YELLOW\nyellow=1" as S_YELLOW
state "S_RED\nred=1" as S_RED
state "S_WALK\nred=1 / walk=1" as S_WALK

S_GREEN  --> S_YELLOW : timer 満了
S_GREEN  --> S_GREEN  : btn 押下\n(btn_req=1)

S_YELLOW --> S_RED    : timer 満了\n[btn_req=0]
S_YELLOW --> S_WALK   : timer 満了\n[btn_req=1]

S_RED    --> S_GREEN  : timer 満了

S_WALK   --> S_GREEN  : timer 満了\n(btn_req クリア)

@enduml
